{
  "name": "bpallocation",
  "private": true,
  "scripts": {
    "start": "meteor run",
    "dev": "meteor --settings privateSettings.json run",
    "visualize": "meteor --production --extra-packages bundle-visualizer",
    "build": "meteor build --server-only --directory ../allocation",
    "test": "meteor --settings privateSettings.json test --once --driver-package meteortesting:mocha --port 3333",
    "test:coverage": "BABEL_ENV=COVERAGE COVERAGE=1 COVERAGE_APP_FOLDER=$PWD/ COVERAGE_OUT_HTML=1 meteor --settings privateSettings.json test --once --driver-package meteortesting:mocha --port 3333",
    "test:watch": "meteor --settings privateSettings.json test --driver-package meteortesting:mocha --port 3333",
    "test:app": "TEST_WATCH=1 TEST_BROWSER_DRIVER=chrome meteor --settings privateSettings.json test --full-app --driver-package meteortesting:mocha --port 3333",
    "test:server": "TEST_WATCH=1 meteor --settings privateSettings.json test --full-app --driver-package meteortesting:mocha --port 3333 TEST_CLIENT=0",
    "test:client": "TEST_WATCH=1 meteor --settings privateSettings.json test --full-app --driver-package meteortesting:mocha --port 3333 TEST_SERVER=0",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "generate-types": "GENERATE_TYPES=1 ts-node --project scripts/tsconfig.json scripts/generateTypes.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-router": "1.156.0",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-font-family": "^3.23.1",
    "@tiptap/extension-heading": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-strike": "^3.23.1",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/extension-text-align": "^3.23.1",
    "@tiptap/extension-text-style": "^3.23.1",
    "@tiptap/extension-underline": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.46.1",
    "immutable": "^5.1.5",
    "libphonenumber-js": "^1.13.0",
    "matter-fireworks": "^1.0.2",
    "matter-js": "^0.20.0",
    "meteor-node-stubs": "^1.2.27",
    "mui-tiptap": "^1.30.0",
    "notistack": "^3.0.2",
    "numeral": "^2.0.6",
    "papaparse": "^5.5.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-countdown-circle-timer": "^3.2.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-image": "^4.1.0",
    "react-textarea-autosize": "^8.5.9",
    "simpl-schema": "^3.4.7",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@babel/types": "^7.29.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^1.2.0",
    "@faker-js/faker": "^10.4.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "^5.2.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/meteor": "^2.9.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "@types/numeral": "^2.0.5",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-slider": "^1.3.6",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "babel-plugin-istanbul": "^8.0.0",
    "chai": "^6.2.2",
    "chromedriver": "^148.0.2",
    "commitizen": "^4.3.1",
    "commitlint": "^21.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "instead": "^1.0.3",
    "jest": "^30.4.2",
    "schema-to-types": "^1.2.4",
    "selenium-webdriver": "^4.43.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "babel": {
    "env": {
      "COVERAGE": {
        "plugins": [
          "istanbul"
        ]
      }
    }
  },
  "meteor": {
    "modern": true
  },
  "mocha": {
    "recursive": true
  },
  "browserslist": [
    "defaults"
  ],
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "npm run lint:types && lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint:fix"
    ],
    "*.{md,json,yml}": [
      "git add"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
